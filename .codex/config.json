{
  "$schema": "https://json.schemastore.org/json",
  "projectName": "clientpulse-crm",
  "mode": "hackathon-mvp",
  "description": "ClientPulse CRM 4-hour MVP build configuration for Codex CLI using Next.js 15, Supabase, and Vercel.",
  "defaults": {
    "stack": {
      "frontend": "nextjs-15-app-router",
      "language": "typescript-strict",
      "styling": "tailwindcss",
      "ui": "shadcn-ui-new-york-zinc",
      "backend": "supabase",
      "deployment": "vercel"
    },
    "rules": {
      "serverComponentsByDefault": true,
      "allowClientComponentsOnlyWhenNeeded": true,
      "useShadcnUI": true,
      "avoidRawTailwindOnlyUI": false,
      "preferSimpleCRUD": true,
      "preferMVPOverArchitecture": true,
      "alwaysRunTypecheckAfterTask": true,
      "alwaysFixImports": true,
      "alwaysSummarizeFilesChanged": true,
      "preserveWorkingCode": true,
      "avoidOverEngineering": true
    },
    "buildStrategy": {
      "maxHours": 4,
      "priority": [
        "landing-page",
        "auth",
        "workspace-onboarding",
        "app-shell",
        "clients-crud",
        "pipeline",
        "tasks",
        "dashboard"
      ],
      "cutOrder": [
        "drag-and-drop",
        "client-detail-extras",
        "completed-task-polish",
        "advanced-dashboard",
        "charts",
        "advanced-filters"
      ]
    }
  },
  "paths": {
    "prompts": ".codex/prompts",
    "skills": ".codex/skills",
    "docs": "docs"
  },
  "promptFiles": [
    ".codex/prompts/clientpulse-phase-prompts.md"
  ],
  "skills": [
    "hackathon-mvp-executor"
  ],
  "recommendedCommands": [
    "npm install",
    "npm run lint",
    "npm run build"
  ],
  "taskTemplates": {
    "afterEachPhase": [
      "Run a full typecheck",
      "Fix TypeScript errors",
      "Fix imports",
      "Ensure routes compile",
      "Keep changes minimal"
    ],
    "beforeDeploy": [
      "Create .env.example",
      "Verify middleware",
      "Verify Supabase env vars",
      "Run build",
      "Add /api/healthcheck"
    ]
  },
  "featureConstraints": {
    "mvpOnly": true,
    "noFeatureBloat": true,
    "maxCoreFeatures": 4,
    "preferDemoFlow": true,
    "fallbacks": {
      "pipelineDragDrop": "move-to-next-stage-button",
      "charts": "stat-cards-only",
      "complexSupabaseLogic": "simplify-to-stable-crud"
    }
  },
  "outputPreferences": {
    "requireFileListSummary": true,
    "requireManualStepsSummary": true,
    "requireEnvVarsSummary": true,
    "requireCompileSafeOutput": true
  }
}